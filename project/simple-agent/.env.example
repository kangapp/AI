# Default configuration for Anthropic SDK (MiniMax)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic/v1
MODEL=MiniMax-M2.7
PROVIDER=anthropic

# MiniMax MCP 配置 (可选)
# 启用 MiniMax MCP (需要先安装 uvx: curl -LsSf https://astral.sh/uv/install.sh | sh)
ENABLE_MINIMAX_MCP=false
# API Key 和 Host 默认使用上面的 ANTHROPIC_API_KEY 和 ANTHROPIC_BASE_URL
